rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default safety catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Seuls les comptes Google de la famille ont accès aux données.
    // IMPORTANT : ajoutez ici les adresses exactes utilisées pour vous
    // connecter à l'application (bouton "Se connecter avec Google").
    function isFamily() {
      return request.auth != null
        && request.auth.token.email_verified == true
        && request.auth.token.email in [
          'matthieu.milliot@wearemip.com'
          // , 'adresse.helene@gmail.com'
        ];
    }

    function isValidVoyageur(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 128;
    }

    match /voyageurs/{id} {
      allow read, list: if isFamily();
      allow create, update: if isFamily() && isValidVoyageur(request.resource.data);
      allow delete: if isFamily();
    }
  }
}
